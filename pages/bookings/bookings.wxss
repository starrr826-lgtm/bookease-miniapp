/* pages/bookings/bookings.wxss */

/* ===== 顶部子 Tab ===== */
.sub-tabs {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 8rpx;
  margin-bottom: var(--sp-3);
  box-shadow: var(--shadow-tab);
}
.sub-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: var(--fs-base);
  color: var(--color-text-secondary);
  border-radius: var(--radius-tab);
  transition: background var(--dur-normal);
}
.sub-tab.active {
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-weight: 600;
}

/* ===== 状态筛选行 ===== */
.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--sp-3);
  overflow-x: auto;
}
.filter-chip {
  padding: 10rpx var(--sp-3);
  font-size: var(--fs-sm);
  color: var(--color-text-secondary);
  background: var(--color-card);
  border-radius: var(--radius-pill);
  flex-shrink: 0;
  box-shadow: var(--shadow-tab);
  transition: background var(--dur-normal), color var(--dur-normal);
}
.filter-chip.active {
  background: var(--color-primary);
  color: var(--color-on-primary);
  box-shadow: none;
}

/* ===== 单按钮行（左对齐，不用 space-between）===== */
.action-row {
  display: flex;
  align-items: center;
}

/* op-btn / op-primary / op-danger 已提升至 app.wxss */
