/* pages/my/my.wxss */

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  padding: var(--sp-4) var(--sp-3);
  background: linear-gradient(135deg, #FDF0E6 0%, #FFFFFF 60%);
}

/* 头像容器：作为 flex item 和圆形裁剪层 */
.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: var(--sp-3);
}
.avatar-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
}
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: 52rpx;
  font-weight: 600;
  text-align: center;
  line-height: 120rpx;
}
/* button 铺满容器作为透明点击层，不参与布局 */
.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  opacity: 0;
}
.avatar-btn::after { display: none; }
.user-info { flex: 1; min-width: 0; }

/* 昵称输入框 */
.nickname-input {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  width: 100%;
}
.nickname-placeholder {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--color-text-disabled);
}

/* ===== 标题行 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--sp-1) var(--sp-1) var(--sp-2);
}
.section-label {
  font-size: var(--fs-base);
  font-weight: 500;
  color: var(--color-text-secondary);
}
.create-btn {
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: var(--fs-sm);
  font-weight: 500;
  padding: 10rpx var(--sp-4);
  border-radius: var(--radius-pill);
  line-height: 1;
  box-shadow: var(--shadow-btn);
}

/* ===== 日程表卡片 ===== */
.schedule-card   { padding-bottom: var(--sp-2); }
.schedule-body   { padding-bottom: 4rpx; }
.schedule-name {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.schedule-meta {
  font-size: var(--fs-sm);
  color: var(--color-text-secondary);
}
.key-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: var(--color-primary-light);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-chip);
  padding: 2rpx 12rpx 2rpx 10rpx;
}
.key-text {
  color: var(--color-primary);
  font-weight: 500;
}
.key-copy-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

/* ===== 操作行 ===== */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: var(--sp-1);
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}
.action-icon {
  width: 44rpx;
  height: 44rpx;
}
.action-label {
  font-size: var(--fs-xs);
  color: #8A8178;
  line-height: 1;
}
/* 分享按钮重置微信默认样式 */
.action-share-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  font-weight: 400;
}
.action-share-btn::after { display: none; }
