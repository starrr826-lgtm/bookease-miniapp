/* pages/my/my.wxss */

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  padding: var(--sp-4) var(--sp-3);
  background: linear-gradient(135deg, #FDF0E6 0%, #FFFFFF 60%);
}
.avatar-img,
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: var(--sp-3);
  flex-shrink: 0;
}
.avatar-placeholder {
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: 52rpx;
  font-weight: 600;
  text-align: center;
  line-height: 120rpx;
}
.user-info { flex: 1; min-width: 0; }
.nickname {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 标题行 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--sp-1) var(--sp-1) var(--sp-2);
}
.section-label {
  font-size: var(--fs-base);
  font-weight: 500;
  color: var(--color-text-secondary);
}
.create-btn {
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: var(--fs-sm);
  font-weight: 500;
  padding: 10rpx var(--sp-4);
  border-radius: var(--radius-pill);
  line-height: 1;
  box-shadow: var(--shadow-btn);
}

/* ===== 日程表卡片 ===== */
.schedule-card   { padding-bottom: var(--sp-2); }
.schedule-body   { padding-bottom: 4rpx; }
.schedule-name {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.schedule-meta {
  font-size: var(--fs-sm);
  color: var(--color-text-secondary);
}
.key-text {
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 操作行 ===== */
.action-copy  { color: var(--color-accent); }
.action-group {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.action-edit  { color: var(--color-primary); }
.action-divider {
  width: 1rpx;
  height: 24rpx;
  background: var(--color-border);
}
.action-delete { color: var(--color-danger); }
