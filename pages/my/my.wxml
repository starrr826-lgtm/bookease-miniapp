<!-- pages/my/my.wxml -->
<view class="container">

  <!-- 用户卡片 -->
  <view class="card user-card">
    <view class="avatar-wrap">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">{{nickname ? nickname[0] : '?'}}</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar"></button>
    </view>
    <view class="user-info">
      <input
        class="nickname-input"
        type="nickname"
        value="{{nickname}}"
        placeholder="点击填写昵称"
        placeholder-class="nickname-placeholder"
        bindblur="onNicknameBlur"
      />
      <view class="text-small text-muted" style="margin-top: 4rpx;">点击头像换图 · 点击昵称编辑</view>
    </view>
  </view>

  <!-- 日程表区标题行 -->
  <view class="section-header">
    <view class="section-label">我的日程表</view>
    <view class="create-btn" bindtap="goCreate">＋ 新建</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-inline text-small text-muted">加载中…</view>

  <!-- 列表 -->
  <block wx:elif="{{schedules.length > 0}}">
    <view wx:for="{{schedules}}" wx:key="_id" class="card schedule-card">
      <!-- 点击主体进入编辑 -->
      <view class="schedule-body" bindtap="openSchedule" data-id="{{item._id}}">
        <view class="schedule-name">{{item.name}}</view>
        <view class="schedule-meta">
          分享码
          <view class="key-chip" catchtap="copyShareKey" data-key="{{item.qrCodeKey}}">
            <text class="key-text">{{item.qrCodeKey}}</text>
            <image class="key-copy-icon" src="/assets/icons/action-copy.svg" mode="aspectFit"/>
          </view>
          · {{item.status === 0 ? '已停用' : '已启用'}}
        </view>
      </view>
      <view class="divider"></view>
      <!-- 操作行 -->
      <view class="action-row">
        <view class="action-item" catchtap="showQRCode" data-id="{{item._id}}" data-key="{{item.qrCodeKey}}" data-name="{{item.name}}">
          <image class="action-icon" src="/assets/icons/action-qr.svg" mode="aspectFit"/>
          <text class="action-label">二维码</text>
        </view>
        <button class="action-item action-share-btn" open-type="share" data-key="{{item.qrCodeKey}}" data-name="{{item.name}}">
          <image class="action-icon" src="/assets/icons/action-share.svg" mode="aspectFit"/>
          <text class="action-label">分享链接</text>
        </button>
        <view class="action-item" catchtap="openSchedule" data-id="{{item._id}}">
          <image class="action-icon" src="/assets/icons/action-edit.svg" mode="aspectFit"/>
          <text class="action-label">编辑</text>
        </view>
        <view class="action-item" catchtap="deleteSchedule" data-id="{{item._id}}" data-name="{{item.name}}">
          <image class="action-icon" src="/assets/icons/action-delete.svg" mode="aspectFit"/>
          <text class="action-label">删除</text>
        </view>
      </view>
    </view>
  </block>

  <!-- QR 弹窗 -->
  <view wx:if="{{qrVisible}}" class="qr-overlay" catchtap="closeQR">
    <view class="qr-card" catchtap="stopPropagation">
      <view class="qr-schedule-name">{{qrScheduleName}}</view>
      <view wx:if="{{qrLoading}}" class="qr-loading text-small text-muted">生成中…</view>
      <image wx:elif="{{qrUrl}}" class="qr-image" src="{{qrUrl}}" mode="aspectFit"></image>
      <view class="text-small text-muted" style="margin-top: 16rpx;">长按二维码可保存到相册</view>
      <view class="qr-actions">
        <view class="op-btn op-outline" catchtap="closeQR">关闭</view>
        <button class="op-btn op-primary" open-type="share" data-key="{{qrScheduleKey}}" data-name="{{qrScheduleName}}">分享给朋友</button>
      </view>
    </view>
  </view>

  <!-- 空态 -->
  <view wx:else class="empty">
    <view>还没有日程表</view>
    <view class="text-small text-muted" style="margin-top:12rpx;">点击右上角「＋ 新建」创建第一个</view>
  </view>

</view>
