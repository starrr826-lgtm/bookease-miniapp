<!-- pages/editSchedule/editSchedule.wxml -->
<view class="container">
  <!-- 日程表名称 -->
  <view class="card">
    <view class="field-label">营业日程表名称</view>
    <input class="input" placeholder="如：满满的美甲店" value="{{name}}" bindinput="onInputName" />
  </view>

  <!-- 服务项目 -->
  <view class="card">
    <view class="field-label">服务项目及时长</view>
    <view wx:for="{{items}}" wx:key="key" class="item-row">
      <input class="input-inline flex2" placeholder="如：卸甲，延长款式" value="{{item.name}}" data-idx="{{index}}" bindinput="onInputItemName" />
      <input class="input-inline flex1" type="number" placeholder="如：60" value="{{item.durationMinutes}}" data-idx="{{index}}" bindinput="onInputItemDuration" />
      <text class="unit-label">分钟</text>
      <image class="mini-btn danger" src="/assets/icons/action-remove.svg" mode="aspectFit" bindtap="removeItem" data-idx="{{index}}"/>
    </view>
    <view class="add-row" bindtap="addItem">+ 添加项目</view>
  </view>

  <!-- 周循环时段 -->
  <view class="card">
    <view class="field-label">可预约时段（每周循环）</view>
    <view wx:for="{{weeklySlots}}" wx:key="dayOfWeek" wx:for-item="day">
      <view class="day-header">{{day.name}}</view>
      <view wx:for="{{day.slots}}" wx:key="key" wx:for-item="slot" wx:for-index="sIdx" class="slot-row">
        <picker mode="time" value="{{slot.startTime}}" data-dow="{{day.dayOfWeek}}" data-sidx="{{sIdx}}" data-field="startTime" bindchange="onTimeChange">
          <view class="time-picker">{{slot.startTime}}</view>
        </picker>
        <text class="time-sep">-</text>
        <picker mode="time" value="{{slot.endTime}}" data-dow="{{day.dayOfWeek}}" data-sidx="{{sIdx}}" data-field="endTime" bindchange="onTimeChange">
          <view class="time-picker">{{slot.endTime}}</view>
        </picker>
        <image class="mini-btn danger" src="/assets/icons/action-remove.svg" mode="aspectFit" bindtap="removeSlot" data-dow="{{day.dayOfWeek}}" data-sidx="{{sIdx}}"/>
      </view>
      <view class="add-slot" bindtap="addSlot" data-dow="{{day.dayOfWeek}}">+ 添加时段</view>
    </view>
  </view>

  <!-- 保存 -->
  <view class="btn-primary" bindtap="onSave">保存</view>

  <!-- 分享卡（编辑已有日程表时显示）-->
  <view wx:if="{{scheduleId}}" class="card share-card">
    <view class="row-between">
      <view>
        <view class="text-small text-muted">分享码 {{qrCodeKey}}</view>
      </view>
    </view>
  </view>

  <!-- QR 弹窗 -->
  <view wx:if="{{qrVisible}}" class="qr-overlay" catchtap="closeQR">
    <view class="qr-card" catchtap="stopPropagation">
      <view class="qr-schedule-name">{{name}}</view>
      <view wx:if="{{qrLoading}}" class="qr-loading text-small text-muted">生成中…</view>
      <image wx:elif="{{qrUrl}}" class="qr-image" src="{{qrUrl}}" mode="aspectFit"></image>
      <view class="text-small text-muted" style="margin-top: 16rpx;">长按二维码可保存到相册</view>
      <view class="qr-actions">
        <view class="op-btn op-outline" catchtap="closeQR">关闭</view>
        <button class="op-btn op-primary" open-type="share" data-key="{{qrCodeKey}}" data-name="{{name}}">分享给朋友</button>
      </view>
    </view>
  </view>
</view>
