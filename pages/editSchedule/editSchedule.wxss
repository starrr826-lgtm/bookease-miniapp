/* pages/editSchedule/editSchedule.wxss */

.field-label {
  font-size: var(--fs-sm);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* 问题1：用 height + line-height 代替 padding 控制垂直尺寸，避免撑出卡片 */
.input {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: var(--fs-base);
  background: var(--color-muted-bg);
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
}

.input-inline {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: var(--fs-base);
  background: var(--color-muted-bg);
  color: var(--color-text-primary);
}

.flex1 { flex: 1; }
.flex2 { flex: 2; }

.item-row {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-2);
}

.add-row {
  text-align: center;
  color: var(--color-primary);
  font-size: var(--fs-base);
  padding: 18rpx 0;
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--radius-sm);
  margin-top: var(--sp-1);
}

.day-header {
  font-size: var(--fs-base);
  color: var(--color-text-primary);
  font-weight: 500;
  padding: 16rpx 0 8rpx;
  border-top: 1rpx solid var(--color-border);
  margin-top: var(--sp-1);
}

.day-header:first-child {
  border-top: none;
  margin-top: 0;
}

/* 问题2：picker flex:1 撑满剩余空间，删除键紧跟其后不留空隙 */
.slot-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 12rpx;
}
.slot-row picker {
  flex: 1;
}

.time-picker {
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-muted-bg);
  font-size: var(--fs-base);
  color: var(--color-text-primary);
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.time-sep {
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

/* 问题3：× 图标按钮，去掉 margin-left:auto，尺寸收紧 */
.mini-btn {
  flex-shrink: 0;
}

.mini-btn.danger {
  width: 44rpx;
  height: 44rpx;
}

.unit-label {
  font-size: var(--fs-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  white-space: nowrap;
}

.add-slot {
  font-size: var(--fs-sm);
  color: var(--color-accent);
  padding: 10rpx 0;
}

/* ===== 分享卡 ===== */
.share-card { margin-top: var(--sp-2); }
.share-action-group {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.action-qr { color: var(--color-primary); }
.action-share {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  font-size: var(--fs-sm);
  color: var(--color-accent);
  line-height: normal;
  font-weight: 400;
}
.action-share::after { display: none; }
