/* pages/book/book.wxss */

.summary-card {
  border-left: 6rpx solid #07c160;
}
.summary-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}
.summary-line {
  display: flex;
  font-size: 28rpx;
  line-height: 1.8;
}
.summary-line .label {
  color: #888;
  width: 120rpx;
  flex-shrink: 0;
}
.summary-line .value {
  color: #333;
  flex: 1;
}

.form-card {
  padding: 8rpx 24rpx;
}
.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.field:last-child {
  border-bottom: none;
}
.field-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 10rpx;
}
.field-input {
  width: 100%;
  font-size: 30rpx;
  color: #222;
  padding: 8rpx 0;
  box-sizing: border-box;
}
.field-textarea {
  width: 100%;
  font-size: 30rpx;
  color: #222;
  padding: 8rpx 0;
  min-height: 80rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin: 32rpx 0 16rpx;
}

.tips {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  line-height: 1.6;
}
