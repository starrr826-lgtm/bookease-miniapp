/* pages/schedule/schedule.wxss */

/* 顶部子 tab */
.sub-tabs {
  display: flex;
  background: #fff;
  border-radius: 14rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}
.sub-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
}
.sub-tab.active {
  background: #07c160;
  color: #fff;
  font-weight: 600;
}

/* 他人列表项 */
.visited-item { align-items: center; }
.visited-right { display: flex; flex-direction: column; align-items: flex-end; }
.text-green { color: #07c160; font-weight: 500; }

/* 未创建日程表态 */
.no-schedule-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}
.no-schedule-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.no-schedule-title { font-size: 32rpx; font-weight: 600; color: #222; margin-bottom: 12rpx; }
.no-schedule-desc { font-size: 26rpx; color: #999; }

/* 详情态头部 */
.detail-header { position: relative; padding-top: 50rpx; }
.back-btn {
  position: absolute;
  top: 16rpx;
  left: 20rpx;
  font-size: 28rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
}
.detail-title { font-size: 34rpx; font-weight: 600; color: #222; }

/* Chip */
.chip-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 20rpx; }
.chip {
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  min-width: 180rpx;
}
.chip.active { border-color: #07c160; background: #e6f7ee; }
.chip-main { font-size: 28rpx; color: #222; font-weight: 500; }
.chip-sub { font-size: 24rpx; color: #888; margin-top: 4rpx; }

/* 月历 */
.calendar-card { padding: 16rpx 10rpx; }
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 16rpx 16rpx;
}
.calendar-nav {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  color: #07c160;
  font-size: 40rpx;
  font-weight: 600;
}
.calendar-title { font-size: 32rpx; font-weight: 600; color: #222; }
.calendar-weekrow { display: flex; padding: 0 4rpx 4rpx; }
.calendar-weekcell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
}
.calendar-grid { display: flex; flex-wrap: wrap; padding: 0 4rpx; }
.calendar-cell {
  width: calc(100% / 7);
  aspect-ratio: 1 / 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}
.calendar-day {
  font-size: 28rpx;
  color: #222;
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  text-align: center;
  border-radius: 50%;
}
.calendar-cell.other-month .calendar-day { color: #ccc; }

/* 今日标识：绿色描边圆 */
.calendar-cell.today .calendar-day {
  border: 2rpx solid #07c160;
  color: #07c160;
  font-weight: 600;
}
/* 选中：填充绿色 */
.calendar-cell.selected .calendar-day {
  background: #07c160;
  color: #fff;
  font-weight: 600;
  border: none;
}
/* 今日且选中 */
.calendar-cell.today.selected .calendar-day {
  background: #07c160;
  color: #fff;
  border: none;
}

/* 多色点 */
.dot-row {
  position: absolute;
  bottom: 6rpx;
  display: flex;
  gap: 4rpx;
  align-items: center;
  justify-content: center;
}
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}
.dot-business { background: #07c160; }
.dot-booking { background: #ff9500; }
.dot-available { background: #007aff; }
.dot-selected { background: rgba(255, 255, 255, 0.85); }

/* 图例 */
.legend-row {
  display: flex;
  gap: 32rpx;
  padding: 0 8rpx 16rpx;
  margin-top: -8rpx;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #888;
}
.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

/* 分享码输入行 */
.key-input-row { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 24rpx; }
.key-input {
  flex: 1;
  font-size: 28rpx;
  color: #222;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  height: 64rpx;
  box-sizing: border-box;
}
.key-search-btn {
  flex-shrink: 0;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 28rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

/* 营业时段 - 查看态 */
.slot-display-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
}
.slot-time-tag {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
}
.override-badge {
  font-size: 20rpx;
  color: #07c160;
  background: #e6f7ee;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}
.slot-link-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 营业时段 - 编辑态 */
.slot-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.time-picker-box {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
  color: #222;
  min-width: 110rpx;
  text-align: center;
}
.time-sep { font-size: 26rpx; color: #999; flex-shrink: 0; }
.mini-btn-danger {
  color: #e74c3c;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.add-slot-row {
  color: #07c160;
  font-size: 26rpx;
  padding: 16rpx 0 8rpx;
}
.edit-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  justify-content: flex-end;
}
.btn-outline-sm {
  font-size: 26rpx;
  padding: 14rpx 30rpx;
  border-radius: 10rpx;
  border: 2rpx solid #ccc;
  color: #666;
}
.btn-green-sm {
  font-size: 26rpx;
  padding: 14rpx 30rpx;
  border-radius: 10rpx;
  background: #07c160;
  color: #fff;
  font-weight: 500;
}

/* 取消预约按钮 */
.cancel-btn {
  font-size: 24rpx;
  color: #e74c3c;
  border: 1rpx solid #e74c3c;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

/* 时段 */
.time-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.time-chip {
  background: #fff;
  border: 2rpx solid #07c160;
  color: #07c160;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 状态标签 */
.status-tag { font-size: 24rpx; padding: 4rpx 14rpx; border-radius: 20rpx; }
.status-confirmed { background: #e6f7ee; color: #07c160; }
