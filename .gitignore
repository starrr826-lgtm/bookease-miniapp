# —— 依赖目录（npm 安装产物，不上传，clone 后本地/云端会重装） ——
node_modules/
miniprogram_npm/

# 每个云函数自己的依赖
cloudfunctions/*/node_modules/

# —— 系统/编辑器临时文件 ——
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# —— 微信开发者工具私有配置（含本地路径、调试模式、可能含 appid 等） ——
project.private.config.json

# —— 编译产物 / 日志 ——
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# —— 环境变量 / 密钥（如果有） ——
.env
.env.*
!.env.example

# —— 其它 ——
*.tmp
*.bak
